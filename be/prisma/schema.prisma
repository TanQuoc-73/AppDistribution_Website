generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["multiSchema"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  schemas  = ["auth", "public"]
}

model Profile {
  id               String            @id @db.Uuid
  username         String            @unique
  avatarUrl        String?           @map("avatar_url")
  role             UserRole          @default(user)
  is_active        Boolean           @default(true)
  walletBalance    Decimal           @default(0) @map("wallet_balance") @db.Decimal(12, 2)
  last_login_at    DateTime?         @db.Timestamp(6)
  createdAt        DateTime          @default(now()) @map("created_at") @db.Timestamp(6)
  updatedAt        DateTime          @default(now()) @updatedAt @map("updated_at") @db.Timestamp(6)
  cart             Cart[]
  developers       Developer[]
  download_history DownloadHistory[]
  news             News[]
  notifications    Notification[]
  orders           Order[]
  users            users             @relation(fields: [id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  refunds          Refund[]
  review_votes     ReviewVote[]
  reviews          Review[]
  user_library     UserLibrary[]
  wishlists        Wishlist[]

  @@index([role], map: "idx_profiles_role")
  @@map("profiles")
  @@schema("public")
}

model Developer {
  id          String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id     String?   @db.Uuid
  name        String
  slug        String    @unique
  description String?
  logoUrl     String?   @map("logo_url")
  website     String?
  country     String?
  isVerified  Boolean   @default(false) @map("is_verified")
  createdAt   DateTime  @default(now()) @map("created_at") @db.Timestamp(6)
  updatedAt   DateTime  @default(now()) @updatedAt @map("updated_at") @db.Timestamp(6)
  profiles    Profile?  @relation(fields: [user_id], references: [id], onUpdate: NoAction)
  products    Product[]

  @@index([slug], map: "idx_developers_slug")
  @@map("developers")
  @@schema("public")
}

model Category {
  id          String            @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  parentId    String?           @map("parent_id") @db.Uuid
  name        String            @unique
  slug        String            @unique
  description String?
  iconUrl     String?           @map("icon_url")
  sort_order  Int               @default(0)
  createdAt   DateTime          @default(now()) @map("created_at") @db.Timestamp(6)
  parent      Category?         @relation("CategoryTree", fields: [parentId], references: [id], onUpdate: NoAction)
  children    Category[]        @relation("CategoryTree")
  products    ProductCategory[]

  @@index([parentId], map: "idx_categories_parent")
  @@index([slug], map: "idx_categories_slug")
  @@map("categories")
  @@schema("public")
}

model Tag {
  id       String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name     String       @unique
  slug     String       @unique
  products ProductTag[]

  @@map("tags")
  @@schema("public")
}

model Product {
  id               String            @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  developerId      String?           @map("developer_id") @db.Uuid
  name             String
  slug             String            @unique
  shortDescription String?           @map("short_description")
  description      String?
  thumbnailUrl     String?           @map("thumbnail_url")
  price            Decimal           @default(0) @db.Decimal(10, 2)
  discountPercent  Decimal           @default(0) @map("discount_percent") @db.Decimal(5, 2)
  isFree           Boolean           @default(false) @map("is_free")
  is_active        Boolean           @default(true)
  is_featured      Boolean           @default(false)
  ageRating        AgeRating         @default(everyone) @map("age_rating")
  releaseDate      DateTime?         @map("release_date") @db.Date
  createdAt        DateTime          @default(now()) @map("created_at") @db.Timestamp(6)
  updatedAt        DateTime          @default(now()) @updatedAt @map("updated_at") @db.Timestamp(6)
  cartItems        Cart[]
  download_history DownloadHistory[]
  news             News[]
  orderItems       OrderItem[]
  categories       ProductCategory[]
  media            ProductMedia[]
  platforms        ProductPlatform[]
  tags             ProductTag[]
  versions         ProductVersion[]
  developer        Developer?        @relation(fields: [developerId], references: [id], onUpdate: NoAction)
  reviews          Review[]
  library          UserLibrary[]
  wishlists        Wishlist[]

  @@index([developerId], map: "idx_products_developer")
  @@index([is_active], map: "idx_products_is_active")
  @@index([is_featured], map: "idx_products_is_featured")
  @@index([releaseDate], map: "idx_products_release_date")
  @@index([slug], map: "idx_products_slug")
  @@map("products")
  @@schema("public")
}

model ProductCategory {
  productId  String   @map("product_id") @db.Uuid
  categoryId String   @map("category_id") @db.Uuid
  category   Category @relation(fields: [categoryId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  product    Product  @relation(fields: [productId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@id([productId, categoryId])
  @@index([categoryId], map: "idx_product_categories_cat")
  @@map("product_categories")
  @@schema("public")
}

model ProductTag {
  productId String  @map("product_id") @db.Uuid
  tagId     String  @map("tag_id") @db.Uuid
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  tag       Tag     @relation(fields: [tagId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@id([productId, tagId])
  @@index([tagId], map: "idx_product_tags_tag")
  @@map("product_tags")
  @@schema("public")
}

model ProductPlatform {
  id                     String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  productId              String        @map("product_id") @db.Uuid
  platform               platform_type
  min_os                 String?
  min_processor          String?
  min_memory_mb          Int?
  min_storage_mb         Int?
  min_graphics           String?
  recommendedOs          String?       @map("recommended_os")
  recommended_processor  String?
  recommended_memory_mb  Int?
  recommended_storage_mb Int?
  recommended_graphics   String?
  product                Product       @relation(fields: [productId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@unique([productId, platform])
  @@map("product_platforms")
  @@schema("public")
}

model ProductMedia {
  id        String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  productId String    @map("product_id") @db.Uuid
  mediaType MediaType @default(screenshot) @map("media_type")
  url       String
  caption   String?
  sortOrder Int       @default(0) @map("sort_order")
  product   Product   @relation(fields: [productId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([productId], map: "idx_product_media_product")
  @@map("product_media")
  @@schema("public")
}

model ProductVersion {
  id              String            @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  productId       String            @map("product_id") @db.Uuid
  version         String
  changelog       String?
  downloadUrl     String?           @map("download_url")
  fileSize        BigInt?           @map("file_size")
  isLatest        Boolean           @default(false) @map("is_latest")
  createdAt       DateTime          @default(now()) @map("created_at") @db.Timestamp(6)
  downloadHistory DownloadHistory[]
  product         Product           @relation(fields: [productId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@unique([productId, version])
  @@index([productId], map: "idx_product_versions_prod")
  @@map("product_versions")
  @@schema("public")
}

model Coupon {
  id              String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  code            String        @unique
  description     String?
  discount_type   discount_type @default(percentage)
  discountValue   Decimal       @map("discount_value") @db.Decimal(10, 2)
  min_order_value Decimal       @default(0) @db.Decimal(10, 2)
  max_discount    Decimal?      @db.Decimal(10, 2)
  max_uses        Int?
  usedCount       Int           @default(0) @map("used_count")
  isActive        Boolean       @default(true) @map("is_active")
  validFrom       DateTime      @default(now()) @map("valid_from") @db.Timestamp(6)
  validUntil      DateTime?     @map("valid_until") @db.Timestamp(6)
  createdAt       DateTime      @default(now()) @map("created_at") @db.Timestamp(6)
  orders          Order[]

  @@map("coupons")
  @@schema("public")
}

model Cart {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id   String   @db.Uuid
  productId String   @map("product_id") @db.Uuid
  addedAt   DateTime @default(now()) @map("added_at") @db.Timestamp(6)
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  profiles  Profile  @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@unique([user_id, productId])
  @@index([user_id], map: "idx_cart_user")
  @@map("cart")
  @@schema("public")
}

model Order {
  id             String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id        String         @db.Uuid
  couponId       String?        @map("coupon_id") @db.Uuid
  subtotal       Decimal        @default(0) @db.Decimal(12, 2)
  discountAmount Decimal        @default(0) @map("discount_amount") @db.Decimal(12, 2)
  totalPrice     Decimal        @default(0) @map("total_price") @db.Decimal(12, 2)
  status         OrderStatus    @default(pending)
  payment_method PaymentMethod?
  payment_status PaymentStatus  @default(unpaid)
  notes          String?
  createdAt      DateTime       @default(now()) @map("created_at") @db.Timestamp(6)
  updatedAt      DateTime       @default(now()) @updatedAt @map("updated_at") @db.Timestamp(6)
  orderItems     OrderItem[]
  coupon         Coupon?        @relation(fields: [couponId], references: [id], onUpdate: NoAction)
  profiles       Profile        @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  payment        Payment[]

  @@index([createdAt], map: "idx_orders_created")
  @@index([status], map: "idx_orders_status")
  @@index([user_id], map: "idx_orders_user")
  @@map("orders")
  @@schema("public")
}

model OrderItem {
  id               String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  orderId          String        @map("order_id") @db.Uuid
  productId        String        @map("product_id") @db.Uuid
  product_name     String
  unit_price       Decimal       @db.Decimal(10, 2)
  discount_percent Decimal       @default(0) @db.Decimal(5, 2)
  final_price      Decimal       @db.Decimal(10, 2)
  order            Order         @relation(fields: [orderId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  product          Product       @relation(fields: [productId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  refunds          Refund[]
  user_library     UserLibrary[]

  @@index([orderId], map: "idx_order_items_order")
  @@index([productId], map: "idx_order_items_product")
  @@map("order_items")
  @@schema("public")
}

model Payment {
  id               String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  orderId          String        @map("order_id") @db.Uuid
  gateway          String
  amount           Decimal       @db.Decimal(12, 2)
  currency         String        @default("USD") @db.Char(3)
  status           PaymentStatus @default(unpaid)
  transactionId    String?       @map("transaction_id")
  gateway_response Json?
  paidAt           DateTime?     @map("paid_at") @db.Timestamp(6)
  createdAt        DateTime      @default(now()) @map("created_at") @db.Timestamp(6)
  order            Order         @relation(fields: [orderId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([orderId], map: "idx_payments_order")
  @@map("payments")
  @@schema("public")
}

model UserLibrary {
  id            String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id       String     @db.Uuid
  productId     String     @map("product_id") @db.Uuid
  order_item_id String?    @db.Uuid
  license_key   String?
  acquiredAt    DateTime   @default(now()) @map("acquired_at") @db.Timestamp(6)
  order_items   OrderItem? @relation(fields: [order_item_id], references: [id], onUpdate: NoAction)
  product       Product    @relation(fields: [productId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  profiles      Profile    @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@unique([user_id, productId])
  @@index([user_id], map: "idx_user_library_user")
  @@map("user_library")
  @@schema("public")
}

model Review {
  id           String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id      String       @db.Uuid
  productId    String       @map("product_id") @db.Uuid
  rating       Int          @db.SmallInt
  title        String?
  comment      String?
  is_approved  Boolean      @default(true)
  helpfulCount Int          @default(0) @map("helpful_count")
  createdAt    DateTime     @default(now()) @map("created_at") @db.Timestamp(6)
  updatedAt    DateTime     @default(now()) @updatedAt @map("updated_at") @db.Timestamp(6)
  reviewVotes  ReviewVote[]
  product      Product      @relation(fields: [productId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  profiles     Profile      @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@unique([user_id, productId])
  @@index([productId], map: "idx_reviews_product")
  @@index([user_id], map: "idx_reviews_user")
  @@map("reviews")
  @@schema("public")
}

model ReviewVote {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  reviewId   String   @map("review_id") @db.Uuid
  user_id    String   @db.Uuid
  isHelpful  Boolean  @map("is_helpful")
  created_at DateTime @default(now()) @db.Timestamp(6)
  review     Review   @relation(fields: [reviewId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  profiles   Profile  @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@unique([reviewId, user_id])
  @@map("review_votes")
  @@schema("public")
}

model Wishlist {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id    String   @db.Uuid
  productId  String   @map("product_id") @db.Uuid
  created_at DateTime @default(now()) @db.Timestamp(6)
  product    Product  @relation(fields: [productId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  profiles   Profile  @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@unique([user_id, productId])
  @@index([user_id], map: "idx_wishlists_user")
  @@map("wishlists")
  @@schema("public")
}

model Notification {
  id        String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id   String           @db.Uuid
  type      NotificationType @default(system)
  title     String
  message   String
  link_url  String?
  isRead    Boolean          @default(false) @map("is_read")
  createdAt DateTime         @default(now()) @map("created_at") @db.Timestamp(6)
  profiles  Profile          @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([user_id, isRead], map: "idx_notifications_unread")
  @@index([user_id], map: "idx_notifications_user")
  @@map("notifications")
  @@schema("public")
}

model Refund {
  id            String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  order_item_id String       @db.Uuid
  user_id       String       @db.Uuid
  reason        String
  status        RefundStatus @default(pending)
  admin_notes   String?
  requested_at  DateTime     @default(now()) @db.Timestamp(6)
  processed_at  DateTime?    @db.Timestamp(6)
  order_items   OrderItem    @relation(fields: [order_item_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  profiles      Profile      @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@map("refunds")
  @@schema("public")
}

model DownloadHistory {
  id           String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id      String          @db.Uuid
  product_id   String          @db.Uuid
  versionId    String?         @map("version_id") @db.Uuid
  ipAddress    String?         @map("ip_address") @db.Inet
  downloadedAt DateTime        @default(now()) @map("downloaded_at") @db.Timestamp(6)
  products     Product         @relation(fields: [product_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  profiles     Profile         @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  version      ProductVersion? @relation(fields: [versionId], references: [id], onUpdate: NoAction)

  @@index([product_id], map: "idx_download_product")
  @@index([user_id], map: "idx_download_user")
  @@map("download_history")
  @@schema("public")
}

model Banner {
  id          String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  title       String
  imageUrl    String    @map("image_url")
  linkUrl     String?   @map("link_url")
  sortOrder   Int       @default(0) @map("sort_order")
  isActive    Boolean   @default(true) @map("is_active")
  valid_from  DateTime? @db.Timestamp(6)
  valid_until DateTime? @db.Timestamp(6)
  createdAt   DateTime  @default(now()) @map("created_at") @db.Timestamp(6)

  @@map("banners")
  @@schema("public")
}

model News {
  id          String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  author_id   String?   @db.Uuid
  product_id  String?   @db.Uuid
  title       String
  slug        String    @unique
  excerpt     String?
  content     String
  cover_image String?
  isPublished Boolean   @default(false) @map("is_published")
  publishedAt DateTime? @map("published_at") @db.Timestamp(6)
  createdAt   DateTime  @default(now()) @map("created_at") @db.Timestamp(6)
  updatedAt   DateTime  @default(now()) @updatedAt @map("updated_at") @db.Timestamp(6)
  profiles    Profile?  @relation(fields: [author_id], references: [id], onUpdate: NoAction)
  products    Product?  @relation(fields: [product_id], references: [id], onUpdate: NoAction)

  @@index([isPublished, publishedAt], map: "idx_news_published")
  @@index([slug], map: "idx_news_slug")
  @@map("news")
  @@schema("public")
}


generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        String   @id @default(uuid()) @db.Uuid
  email     String   @unique
  username  String?  @unique
  avatarUrl String?  @map("avatar_url")
  createdAt DateTime @default(now()) @map("created_at")

  orders   Order[]
  reviews  Review[]
  library  UserLibrary[]
  wishlist Wishlist[]

  @@map("users")
}

model Developer {
  id          String   @id @default(uuid()) @db.Uuid
  name        String
  description String?
  website     String?
  createdAt   DateTime @default(now()) @map("created_at")

  products Product[]

  @@map("developers")
}

model Category {
  id   String @id @default(uuid()) @db.Uuid
  name String @unique

  products Product[]

  @@map("categories")
}

model Product {
  id          String   @id @default(uuid()) @db.Uuid
  name        String
  description String?
  price       Decimal  @db.Decimal(10,2)
  developerId String?  @db.Uuid @map("developer_id")
  categoryId  String?  @db.Uuid @map("category_id")
  thumbnail   String?
  releaseDate DateTime? @db.Date @map("release_date")
  createdAt   DateTime @default(now()) @map("created_at")

  developer Developer? @relation(fields: [developerId], references: [id])
  category  Category?  @relation(fields: [categoryId], references: [id])

  versions    ProductVersion[]
  reviews     Review[]
  orderItems  OrderItem[]
  library     UserLibrary[]
  wishlist    Wishlist[]
  screenshots ProductScreenshot[]

  @@map("products")
}

model ProductVersion {
  id          String   @id @default(uuid()) @db.Uuid
  productId   String   @db.Uuid @map("product_id")
  version     String
  changelog   String?
  downloadUrl String?  @map("download_url")
  fileSize    BigInt?  @map("file_size")
  createdAt   DateTime @default(now()) @map("created_at")

  product Product @relation(fields: [productId], references: [id])

  @@map("product_versions")
}

model ProductScreenshot {
  id        String @id @default(uuid()) @db.Uuid
  productId String @db.Uuid @map("product_id")
  imageUrl  String @map("image_url")

  product Product @relation(fields: [productId], references: [id])

  @@map("product_screenshots")
}

model Order {
  id         String   @id @default(uuid()) @db.Uuid
  userId     String   @db.Uuid @map("user_id")
  totalPrice Decimal? @db.Decimal(10,2) @map("total_price")
  status     String   @default("pending")
  createdAt  DateTime @default(now()) @map("created_at")

  user  User @relation(fields: [userId], references: [id])
  items OrderItem[]

  @@map("orders")
}

model OrderItem {
  id        String  @id @default(uuid()) @db.Uuid
  orderId   String  @db.Uuid @map("order_id")
  productId String  @db.Uuid @map("product_id")
  price     Decimal @db.Decimal(10,2)

  order   Order   @relation(fields: [orderId], references: [id])
  product Product @relation(fields: [productId], references: [id])

  @@map("order_items")
}

model UserLibrary {
  id           String   @id @default(uuid()) @db.Uuid
  userId       String   @db.Uuid @map("user_id")
  productId    String   @db.Uuid @map("product_id")
  licenseKey   String?  @map("license_key")
  purchaseDate DateTime @default(now()) @map("purchase_date")

  user    User    @relation(fields: [userId], references: [id])
  product Product @relation(fields: [productId], references: [id])

  @@unique([userId, productId])
  @@map("user_library")
}

model Review {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @db.Uuid @map("user_id")
  productId String   @db.Uuid @map("product_id")
  rating    Int
  comment   String?
  createdAt DateTime @default(now()) @map("created_at")

  user    User    @relation(fields: [userId], references: [id])
  product Product @relation(fields: [productId], references: [id])

  @@unique([userId, productId])
  @@map("reviews")
}

model Wishlist {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @db.Uuid @map("user_id")
  productId String   @db.Uuid @map("product_id")
  createdAt DateTime @default(now()) @map("created_at")

  user    User    @relation(fields: [userId], references: [id])
  product Product @relation(fields: [productId], references: [id])

  @@unique([userId, productId])
  @@map("wishlists")
}